# OpenAI Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# Google Sheets Configuration
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_SHEET_NAME=Invoices

# Gmail Configuration (for email ingestion)
GMAIL_LABEL=INVOICES
GMAIL_POLL_INTERVAL=5m

# Google Drive Configuration (alternative ingestion)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Slack Configuration (human review queue)
SLACK_REVIEW_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx
SLACK_HIGH_VALUE_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx

# Processing Rules
HIGH_VALUE_THRESHOLD=5000
CONFIDENCE_THRESHOLD=0.85
DUPLICATE_CHECK_DAYS=90
MAX_FILE_SIZE_MB=10

# Supported file types
SUPPORTED_FORMATS=pdf,png,jpg,jpeg
